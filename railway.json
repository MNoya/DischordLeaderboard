{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "watchPatterns": [
      "bot/**",
      "alembic/**",
      "alembic.ini",
      "requirements.txt",
      "railway.json"
    ]
  },
  "deploy": {
    "startCommand": "python -u -m bot.main",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
