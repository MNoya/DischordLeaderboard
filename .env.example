# Postgres connection. Local dev: docker `dischord-pg` on :5433. Prod: Supabase pooled connection string (port 6543)
DATABASE_URL=postgresql://postgres:devpw@localhost:5433/dischord

# Discord bot credentials. Get from https://discord.com/developers/applications -> your app -> Bot tab
DISCORD_BOT_TOKEN=

# Numeric ID of the dev/test guild that gets instant `!sync` updates. Production servers receive commands via global propagation
DISCORD_GUILD_ID=

# Optional: role allowed to invoke admin commands; channel for bot-internal logging
DISCORD_ADMIN_ROLE_ID=
DISCORD_BOTLOG_CHANNEL_ID=

# Public URL of the leaderboard site (linked from /leaderboard buttons). Defaults to the live placeholder
PUBLIC_SITE_URL=https://dischordboard.netlify.app
