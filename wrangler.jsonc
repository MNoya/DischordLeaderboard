{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "dischordboard",
  "compatibility_date": "2026-05-06",
  "observability": {
    "enabled": true
  },
  "assets": {
    // Serves the built React app. Run `npm --prefix frontend run build` before
    // `wrangler deploy` (or rely on Cloudflare Pages' build command — see
    // README / dashboard).
    "directory": "frontend/dist"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
