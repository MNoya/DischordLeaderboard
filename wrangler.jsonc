{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "dischordboard",
  "compatibility_date": "2026-05-06",
  "observability": {
    "enabled": true
  },
  "build": {
    // Workers Builds runs this before `wrangler deploy`. Vite emits the SPA
    // into frontend/dist/ which is then served by assets below.
    "command": "cd frontend && npm install && npm run build"
  },
  "assets": {
    "directory": "frontend/dist"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
